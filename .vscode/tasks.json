{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Graphify: update graph",
      "type": "shell",
      "command": "graphify",
      "args": [
        "update",
        ".",
        "--no-cluster"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Graphify: cluster and refresh report",
      "type": "shell",
      "command": "graphify",
      "args": [
        "cluster-only",
        "${workspaceFolder}",
        "--no-label"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}